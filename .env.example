# --- LLM ---
OPENAI_API_KEY=sk-...
# Any OpenAI-compatible endpoint works (OpenRouter, GLM, Ollama...)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# mock | openai | hybrid  (hybrid: first REAL_BRAIN_COUNT agents get real brains)
BRAIN_MODE=mock
REAL_BRAIN_COUNT=3

# --- World ---
PORT=8080
MAX_AGENTS=20
MIN_POPULATION=5
DECISION_INTERVAL_MS=15000
MAX_CONCURRENT_LLM=4
LLM_RPM_CAP=60
DAILY_USD_BUDGET=15

# --- Admin ---
ADMIN_PASSWORD=change-me
